# ============================================
# Harmonia — Environment Variables
# ============================================
# Getting started:
#   1. cp .env.example .env.local
#   2. Fill in your values below
#   3. pnpm install
#   4. pnpm dev
#
# Package manager: pnpm (https://pnpm.io)
# ============================================

# Anthropic API Key (for AI features)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# EmailJS — Password Reset via Email
# 1. Create a free account at https://www.emailjs.com
# 2. Add a Gmail service → copy the Service ID
# 3. Create a template with variables: {{to_email}}, {{code}}, {{app_name}}
#    - Subject: "{{app_name}} — Verification Code"
#    - Body: "Your verification code is: {{code}}"
# 4. Copy Template ID and Public Key (Account > API Keys)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
